// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id
  firstName       String    @db.VarChar(50)
  lastName        String    @db.VarChar(50)
  email           String    @unique
  created_at      String    @db.VarChar(25)
  updated_at      String    @db.VarChar(25)
  password        String
  phone           String    @db.VarChar(15)
  emailIsVerified Boolean   @default(false)
  permissions     String[]
  addresses       Address[]
  products        Product[]
}

model Address {
  id         String  @id
  name       String  @db.VarChar(15)
  address    String  @db.VarChar(50)
  address2   String? @db.VarChar(45)
  district   String? @db.VarChar(50)
  state      String? @db.VarChar(50)
  created_at String  @db.VarChar(25)
  updated_at String  @db.VarChar(25)
  city       String  @db.VarChar(35)
  postalCode String  @db.VarChar(15)
  userId     String

  User User @relation(fields: [userId], references: [id])
}

model Product {
  id          String   @id
  name        String   @unique @db.VarChar(50)
  price       Float
  discount    Float?
  description String   @db.VarChar(600)
  category    String   @db.VarChar(50)
  created_at  String   @db.VarChar(25)
  updated_at  String   @db.VarChar(25)
  images      String[]
  available   Boolean
  created_by  String

  User User @relation(fields: [created_by], references: [id])
}

model Order {
  id               String      @id @default(uuid())
  customerName     String      @map("customer_name") @db.VarChar(100)
  customerLastName String      @map("customer_last_name") @db.VarChar(100)
  customerPhone    String      @map("customer_phone") @db.VarChar(20)
  deliveryAddress  String      @map("delivery_address") @db.VarChar(200)
  district         String?     @db.VarChar(50)
  city             String      @db.VarChar(50)
  state            String?     @db.VarChar(50)
  postalCode       String      @map("postal_code") @db.VarChar(15)
  paymentMethod    String      @map("payment_method") @db.VarChar(20)
  totalAmount      Float       @map("total_amount")
  status           String      @default("pending") @db.VarChar(20)
  created_at       String      @map("created_at") @db.VarChar(25)
  items            OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id") @db.VarChar(50)
  productName String  @map("product_name") @db.VarChar(100)
  quantity    Int
  unitPrice   Float   @map("unit_price")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
